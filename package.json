{
  "name": "sinrad",
  "productName": "Sinrad",
  "version": "1.37.0",
  "description": "S.I.R — Personal Command Center (Vault, Links, Quick Folders, device folder search, Console).",
  "main": "main.js",
  "author": {
    "name": "SinSeeker0",
    "email": "SinSeeker0@users.noreply.github.com"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.sinrad.commandcenter",
    "productName": "Sinrad",
    "files": [
      "main.js",
      "preload.js",
      "scan.js",
      "index.html",
      "pet.html",
      "package.json",
      "*.png",
      "*.gif",
      "*.webp",
      "*.svg"
    ],
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "icon.png"
    },
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "icon.ico"
    },
    "linux": {
      "category": "Utility",
      "maintainer": "SinSeeker0 <SinSeeker0@users.noreply.github.com>",
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "icon.png"
    }
  }
}
