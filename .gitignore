# dependencies & build output (never commit these)
node_modules/
dist/
out/
build/

# logs / OS junk
*.log
npm-debug.log*
.DS_Store
Thumbs.db

# built installers (in case any land outside dist/)
*.exe
*.dmg
*.AppImage
*.deb
*.rpm
*.zip
*.blockmap

# editor
.vscode/
.idea/

# NOTE: the image assets (celebrate-*.png, norma.png) and scan.js ARE tracked —
# they ship inside the app. Your personal data (vault/links) is NOT in this
# folder (it lives in your OS app-data), so it's never committed or shared.
